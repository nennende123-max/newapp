<template>
  <div id="app">
    <!-- 全局加载条 -->
    <div v-if="assetStore.isLoading" class="global-loading-bar">
      <van-loading color="#FCD535" vertical size="20px">加载中...</van-loading>
    </div>

    <div class="app-header" v-if="showAppHeader">
