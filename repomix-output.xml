    <div class="confirm-section">
      <van-button 
        block
        class="confirm-btn"
        :class="{ 'enabled': isConfirmEnabled }"
        :disabled="!isConfirmEnabled"
        @click="handleConfirm"
      >
        {{ t('earn.confirm') }}
      </van-button>
    </div>
  </div>
