  border-radius: 30px; 
  box-shadow: 0 0 15px rgba(252, 213, 53, 0.2); 
  pointer-events: none; 
}
.nav-slide-enter-active, .nav-slide-leave-active { 
  transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); 
}
.nav-slide-enter-from, .nav-slide-leave-to { 
  opacity: 0; 
  transform: translate(-50%, -20px); 
}

/* 导航头 */
.nav-header { 
