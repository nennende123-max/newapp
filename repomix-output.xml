                {{ formatPrice(trade?.price || 0) }}
              </span>
              <span class="trade-amount">{{ formatOrderAmount(trade?.amount || 0) }}</span>
              <span class="trade-time">{{ formatTradeTime(trade?.time || new Date()) }}</span>
            </div>
          </div>
