          :disabled="isLoading"
          @click="handleTestDeposit"
        >
          [测试专用] 模拟到账 1000 USDT
        </van-button>
        <p class="test-hint">
          (真实环境中，这里不会有按钮，而是等待链上自动回调)
        </p>
      </div>

      <van-action-sheet
        v-model:show="showNetworkSheet"
        :actions="networkActions"
        cancel-text="Cancel"
        close-on-click-action
