}

#tv_chart_container {
  width: 100%;
  height: 500px;
  min-height: 500px;
  pointer-events: auto;
}

:deep(#tv_chart_container) {
  width: 100% !important;
  height: 500px !important;
  pointer-events: auto !important;
}
