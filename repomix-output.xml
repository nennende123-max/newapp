<file path="src/style.css">
/* 全局样式 - 图标字体修复 */

/* 确保 Vant 图标字体优先级最高，防止被全局字体覆盖 */
/* Vant 4 使用 iconfont 字体，必须确保不被全局 font-family 覆盖 */
.van-icon,
[class*="van-icon"],
.van-tabbar-item__icon,
.van-field__left-icon,
.van-field__right-icon,
.van-checkbox__icon,
.van-button__icon,
.van-nav-bar__arrow,
.van-nav-bar__right {
  font-family: 'vant-icon', 'vant-iconfont', 'vant-icons', 'iconfont', 'vant', sans-serif !important;
  font-style: normal !important;
  font-weight: normal !important;
  font-variant: normal !important;
  text-transform: none !important;
  line-height: 1 !important;
  vertical-align: baseline !important;
  display: inline-block !important;
  -webkit-font-smoothing: antialiased !important;
  -moz-osx-font-smoothing: grayscale !important;
  speak: none !important;
}

/* 确保图标伪元素使用正确的字体渲染 */
.van-icon::before,
[class*="van-icon"]::before {
  font-family: 'vant-icon', 'vant-iconfont', 'vant-icons', 'iconfont', 'vant', sans-serif !important;
  font-style: normal !important;
  font-weight: normal !important;
}

/* 确保所有包含 van-icon 的元素都使用图标字体 */
* .van-icon,
* [class*="van-icon"] {
  font-family: 'vant-icon', 'vant-iconfont', 'vant-icons', 'iconfont', 'vant', sans-serif !important;
}
