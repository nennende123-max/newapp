  top: 60px; 
  left: 50%; 
  transform: translateX(-50%); 
  background: #1C1C1E; 
  padding: 10px 20px; 
  border-radius: 30px; 
  border: 1px solid #FCD535; 
  z-index: 9999; 
  display: flex; 
  align-items: center; 
  gap: 8px; 
  box-shadow: 0 4px 20px rgba(252, 213, 53, 0.15); 
}
.notif-glow { 
