<file path="src/components/TradingViewWidget.vue">
<template>
  <div class="tradingview-widget-container" ref="container" style="height: 500px; width: 100%">
    <div id="tv_chart_container" style="height: 100%; width: 100%"></div>
  </div>
</template>

<script setup>
import { ref, onMounted, onUnmounted, watch, nextTick } from 'vue';

const props = defineProps({
  symbol: {
    type: String,
    default: 'BINANCE:BTCUSDT' // 默认使用币安 BTC/USDT
  },
  interval: {
    type: String,
    default: '60' // 默认 1小时
  }
});

let tvWidget = null;
const container = ref(null);
const currentPrice = ref(0);
let priceUpdateInterval = null;

// 标准化交易对名称到 TradingView 格式
const normalizeSymbolForTradingView = (symbol) => {
  if (!symbol) return 'BINANCE:BTCUSDT';
  
  let normalized = symbol.toUpperCase().trim();
  
  if (normalized.startsWith('BINANCE:')) {
    return normalized;
  }
  
  if (normalized.includes('/')) {
    normalized = normalized.replace('/', '');
  }
  
  if (!normalized.startsWith('BINANCE:')) {
    normalized = 'BINANCE:' + normalized;
  }
  
  if (!normalized.endsWith('USDT')) {
    normalized = normalized + 'USDT';
  }
  
  return normalized;
};

// 初始化 Widget（确保容器存在且 TradingView 已加载）
const initWidget = () => {
  const containerElement = document.getElementById('tv_chart_container');
  if (!containerElement) {
    console.error('Container #tv_chart_container not found! Check template.');
    return;
  }

  // 清空容器防冲突（仅在容器存在时）
  containerElement.innerHTML = '';

  if (typeof window.TradingView === 'undefined') {
    console.error('TradingView 未加载！检查 index.html 中的 script 标签: https://s3.tradingview.com/tv.js');
    return;
  }

  // 如果已有 widget，先移除
  if (tvWidget) {
    try {
      tvWidget.remove();
    } catch (e) {
      console.error('移除旧 widget 失败:', e);
    }
    tvWidget = null;
  }

  // 标准化交易对名称
  const symbol = normalizeSymbolForTradingView(props.symbol || 'BINANCE:BTCUSDT');
  
  // 标准化时间间隔
  let interval = props.interval || '60';
  if (interval === '1m' || interval === '1') interval = '1';
  if (interval === '5m' || interval === '5') interval = '5';
  if (interval === '15m' || interval === '15') interval = '15';
  if (interval === '1h' || interval === '60') interval = '60';
  if (interval === '4h' || interval === '240') interval = '240';
  if (interval === '1d' || interval === 'D' || interval === '1D') interval = 'D';

  console.log('[TradingView] 初始化图表:', { symbol, interval });

  // 使用最小、最标准的配置
  tvWidget = new window.TradingView.widget({
    autosize: true,
    symbol: symbol,
    interval: interval,
    timezone: 'Asia/Shanghai',
    theme: 'dark',
    locale: 'zh_CN',
    toolbar_bg: '#1e1e1e',
    enable_publishing: false,
    allow_symbol_change: true,
    container_id: 'tv_chart_container'
  });

  console.log('Widget initialized with real BTCUSDT data');
};

// 从币安 API 获取当前价格
const fetchCurrentPrice = async () => {
  try {
    const symbol = normalizeSymbolForTradingView(props.symbol || 'BINANCE:BTCUSDT');
    const binanceSymbol = symbol.replace('BINANCE:', '');
    
    let url = `https://api.binance.com/api/v3/ticker/price?symbol=${binanceSymbol}`;
    let response;
    
    try {
      response = await fetch(url);
      if (!response.ok) {
        throw new Error(`HTTP ${response.status}`);
      }
    } catch (error) {
      url = `https://data-api.binance.vision/api/v3/ticker/price?symbol=${binanceSymbol}`;
      response = await fetch(url);
    }
    
    const data = await response.json();
    
    if (data && data.price) {
      currentPrice.value = parseFloat(data.price);
      console.log(`[Price] ${binanceSymbol} 当前价格: ${currentPrice.value}`);
    }
  } catch (error) {
    console.error('[Price] 获取价格失败:', error);
  }
};

onMounted(async () => {
  // 先获取当前价格
  await fetchCurrentPrice();

  // 使用 nextTick 确保 DOM 已渲染
  await nextTick();
  
  const containerElement = document.getElementById('tv_chart_container');
  if (!containerElement) {
    console.error('Container #tv_chart_container not found! Check template.');
    return;
  }

  // 检查 TradingView 是否已加载
  if (typeof window.TradingView !== 'undefined') {
    // 已加载，直接初始化
    initWidget();
  } else {
    // 未加载，动态加载 TradingView 库
    const script = document.createElement('script');
    script.src = 'https://s3.tradingview.com/tv.js';
    script.async = true;
    
    script.onload = () => {
      console.log('TradingView 库加载成功');
      initWidget();
    };
    
    script.onerror = () => {
      console.error('Failed to load TradingView library');
    };
    
    // 检查是否已存在相同的脚本
    const existingScript = document.querySelector('script[src="https://s3.tradingview.com/tv.js"]');
    if (!existingScript) {
      document.head.appendChild(script);
    } else {
      // 如果脚本已存在，等待其加载完成
      if (window.TradingView) {
        initWidget();
      } else {
        existingScript.onload = () => {
          initWidget();
        };
      }
    }
  }
  
  // 定时更新价格（每5秒）
  priceUpdateInterval = setInterval(fetchCurrentPrice, 5000);
});

// 监听 props.symbol 变化
watch(
  () => props.symbol,
  (newSymbol) => {
    if (tvWidget && typeof window.TradingView !== 'undefined') {
      try {
        const normalizedSymbol = normalizeSymbolForTradingView(newSymbol);
        console.log('[TradingView] 更新交易对:', normalizedSymbol);
        const interval = props.interval || '60';
        tvWidget.setSymbol(normalizedSymbol, interval, () => {
          console.log('[TradingView] 交易对更新成功');
        });
      } catch (error) {
        console.error('[TradingView] 更新交易对失败:', error);
        setTimeout(initWidget, 500);
      }
    } else if (typeof window.TradingView !== 'undefined') {
      setTimeout(initWidget, 500);
    }
  }
);

// 监听 props.interval 变化
watch(
  () => props.interval,
  (newInterval) => {
    if (tvWidget && typeof window.TradingView !== 'undefined') {
      try {
        console.log('[TradingView] 更新时间间隔:', newInterval);
        tvWidget.setInterval(newInterval || '60', () => {
          console.log('[TradingView] 时间间隔更新成功');
        });
      } catch (error) {
        console.error('[TradingView] 更新时间间隔失败:', error);
        setTimeout(initWidget, 500);
      }
    } else if (typeof window.TradingView !== 'undefined') {
      setTimeout(initWidget, 500);
    }
  }
);

onUnmounted(() => {
  // 清理价格更新定时器
  if (priceUpdateInterval) {
    clearInterval(priceUpdateInterval);
    priceUpdateInterval = null;
  }
  
  // 移除 TradingView widget
  if (tvWidget) {
    try {
      tvWidget.remove();
    } catch (e) {
      console.error('移除 TradingView widget 失败:', e);
    }
    tvWidget = null;
  }
});

// 暴露当前价格供父组件使用
defineExpose({
  currentPrice
});
</script>

<style scoped>
