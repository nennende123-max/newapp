  .history-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 13px;
    color: #FCD535;
    cursor: pointer;
    padding: 10px 14px;
    background-color: rgba(252, 213, 53, 0.1);
    border-radius: 8px;
    transition: all 0.2s ease;
    white-space: nowrap;
