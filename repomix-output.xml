              <span class="bet-info-label">Est. Return</span>
              <span class="bet-info-value text-green">
                ${{ calculateEstReturn().toFixed(2) }} 
                <span class="return-percent">({{ calculateEstReturnPercent().toFixed(1) }}%)</span>
              </span>
            </div>
          </div>
