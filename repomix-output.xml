"""
K 线市场数据 API 端点
提供历史 K 线查询和实时 WebSocket 推送
"""
from fastapi import APIRouter, WebSocket, WebSocketDisconnect, Query, HTTPException
from typing import Optional, List
import json
import logging

from app.models.kline import KlineModel
from app.services.market_service import market_service, register_websocket, unregister_websocket
import ccxt.async_support as ccxt

logger = logging.getLogger(__name__)

# 创建路由实例
router = APIRouter(prefix="/api/v1/market", tags=["market"])


@router.get("/kline")
async def get_kline(
    symbol: str = Query(..., description="交易对，如 BTC/USDT"),
    interval: str = Query("1m", description="时间间隔，如 1m, 5m, 1h"),
    limit: int = Query(1000, ge=1, le=5000, description="返回数量限制"),
    start_time: Optional[int] = Query(None, description="开始时间戳（毫秒）"),
    end_time: Optional[int] = Query(None, description="结束时间戳（毫秒）")
):
    """
    获取 K 线数据
    
    优先从数据库查询，如果数据库为空，临时调用 ccxt 抓取并返回
    """
    try:
        # 标准化交易对格式
        symbol = symbol.upper()
        if '/' not in symbol:
            symbol = f"{symbol}/USDT"
        
        # 先尝试从数据库查询
        klines = await KlineModel.get_klines(symbol, interval, limit, start_time, end_time)
        
        # 如果数据库有数据，直接返回
        if klines:
            return {
                "code": 200,
                "message": "获取 K 线数据成功",
                "data": klines
            }
        
        # 如果数据库为空，临时调用 ccxt 抓取
        logger.info(f"[INFO] 数据库为空，临时从币安抓取 {symbol} {interval} 数据...")
        
        try:
            exchange = ccxt.binance({
                'enableRateLimit': True,
                'options': {'defaultType': 'spot'}
            })
            
            ohlcv = await exchange.fetch_ohlcv(symbol, interval, limit=limit)
            await exchange.close()
            
            if not ohlcv:
                raise HTTPException(status_code=404, detail=f"未找到 {symbol} {interval} 的 K 线数据")
            
            # 转换数据格式
            klines = []
            for candle in ohlcv:
                klines.append({
                    'symbol': symbol,
                    'interval': interval,
                    'timestamp': int(candle[0]),
                    'open': float(candle[1]),
                    'high': float(candle[2]),
                    'low': float(candle[3]),
                    'close': float(candle[4]),
                    'volume': float(candle[5])
                })
            
            return {
                "code": 200,
                "message": "获取 K 线数据成功（临时抓取）",
                "data": klines
            }
            
        except Exception as e:
            logger.error(f"[ERROR] 临时抓取 K 线数据失败: {str(e)}")
            raise HTTPException(status_code=500, detail=f"获取 K 线数据失败: {str(e)}")
    
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"[ERROR] 获取 K 线数据失败: {str(e)}")
        raise HTTPException(status_code=500, detail=f"获取 K 线数据失败: {str(e)}")


@router.websocket("/ws/kline")
async def websocket_kline(websocket: WebSocket):
    """
    K 线实时推送 WebSocket 接口
    
    前端连接此接口后，后端将从币安收到的实时数据转发给前端
    
    消息格式：
    发送给客户端：
    {
        "type": "kline",
        "data": {
            "symbol": "BTC/USDT",
            "interval": "1m",
            "timestamp": 1234567890000,
            "open": 50000.0,
            "high": 51000.0,
            "low": 49000.0,
            "close": 50500.0,
            "volume": 1000.0,
            "is_closed": false
        }
    }
    """
    await websocket.accept()
    await register_websocket(websocket)
    
    try:
        # 发送连接成功消息
        await websocket.send_json({
            "type": "connected",
            "message": "K 线实时推送已连接"
        })
        
        # 保持连接，等待消息
        while True:
            # 可以接收客户端的心跳或订阅请求
            try:
                data = await websocket.receive_text()
                # 解析客户端消息（可选）
                try:
                    message = json.loads(data)
                    if message.get("type") == "ping":
                        await websocket.send_json({"type": "pong"})
                except json.JSONDecodeError:
                    pass
            except WebSocketDisconnect:
                break
            
    except WebSocketDisconnect:
        logger.info("[WS] 客户端主动断开连接")
    except Exception as e:
        logger.error(f"[ERROR] WebSocket 错误: {str(e)}")
    finally:
        await unregister_websocket(websocket)
