            />
            <div class="bet-quick-amounts">
              <span
                v-for="quick in quickAmounts"
                :key="quick"
                class="quick-amount-btn"
                @click="betAmount = quick.toString()"
              >
                {{ quick }}
              </span>
            </div>
          </div>

          <div class="bet-info-section">
