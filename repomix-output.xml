      show-cancel-button
      @confirm="handlePasswordConfirm"
      @cancel="showPasswordDialog = false"
      class="password-dialog"
    >
      <div class="password-input-wrapper">
        <van-field
          v-model="passwordInput"
          type="password"
          placeholder="请输入6位资金密码"
          maxlength="6"
          class="password-field"
          autocomplete="off"
        />
      </div>
    </van-dialog>
  </div>
